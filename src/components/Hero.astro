---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Animated grid background -->
  <div class="absolute inset-0 opacity-15">
    <div class="absolute inset-0 animate-grid-move"
      style="background-image: linear-gradient(rgba(75,165,211,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(75,165,211,0.08) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
  </div>

  <!-- Gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-nc-warm-light/15 rounded-full blur-3xl animate-pulse-glow"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-nc-sky-light/12 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 1.5s;"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-nc-deep-light/55 rounded-full blur-3xl"></div>

  <!-- Floating particles -->
  <div class="absolute top-20 left-[15%] w-2 h-2 bg-nc-sky/40 rounded-full animate-float" style="animation-delay: 0s;"></div>
  <div class="absolute top-40 right-[20%] w-1.5 h-1.5 bg-nc-sky/30 rounded-full animate-float" style="animation-delay: 1s;"></div>
  <div class="absolute bottom-32 left-[25%] w-1 h-1 bg-nc-sky/50 rounded-full animate-float" style="animation-delay: 2s;"></div>
  <div class="absolute top-[60%] right-[10%] w-2.5 h-2.5 bg-nc-sky/20 rounded-full animate-float" style="animation-delay: 3s;"></div>
  <div class="absolute bottom-40 right-[30%] w-1.5 h-1.5 bg-nc-sky/35 rounded-full animate-float" style="animation-delay: 0.5s;"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto w-full max-w-[95vw] lg:max-w-7xl px-4 sm:px-6 text-center">
    <div class="relative mx-auto w-full max-w-6xl rounded-[2rem] border border-white/10 bg-nc-deep-light/35 px-5 py-8 sm:px-8 sm:py-10 shadow-2xl shadow-black/20 backdrop-blur-xl">
      <!-- Badge -->
      <div class="scroll-animate fade-up inline-flex items-center gap-2 px-4 py-2 mb-8 border border-nc-sky/20 rounded-full bg-nc-sky/8 backdrop-blur-sm">
        <span class="w-2 h-2 bg-nc-sky rounded-full animate-pulse"></span>
        <span class="text-nc-sky text-sm font-medium">Desarrollo de Software a Medida</span>
      </div>

      <!-- Title -->
      <h1 class="scroll-animate fade-up delay-100 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight text-white">
        Construimos el software
        <br />
        <span class="text-nc-warm">que tu negocio necesita</span>
      </h1>

      <!-- Subtitle -->
      <p class="scroll-animate fade-up delay-200 mt-5 text-lg md:text-xl text-nc-light/85 max-w-2xl mx-auto leading-relaxed">
        Transformamos ideas en soluciones digitales escalables, modernas y de alto rendimiento. Tu visión, nuestra ingeniería.
      </p>
    </div>

    <!-- CTAs -->
    <div class="scroll-animate fade-up delay-300 mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contact"
        class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-nc-warm to-nc-sky text-white font-semibold rounded-xl hover:shadow-xl hover:shadow-nc-sky/25 transition-all duration-300 hover:-translate-y-1"
      >
        Solicitar Propuesta
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#services"
        class="inline-flex items-center gap-2 px-8 py-4 border border-nc-slate/25 text-white font-medium rounded-xl hover:bg-nc-sky/10 hover:border-nc-sky/20 transition-all duration-300"
      >
        Ver Servicios
      </a>
    </div>

    <!-- Stats -->
    <div class="scroll-animate fade-up delay-400 mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-bold text-white">50+</div>
        <div class="text-sm text-nc-gray/75 mt-1">Proyectos</div>
      </div>
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-bold text-white">30+</div>
        <div class="text-sm text-nc-gray mt-1">Clientes</div>
      </div>
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-bold text-white">99%</div>
        <div class="text-sm text-nc-gray mt-1">Satisfacción</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
</section>
